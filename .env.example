# Optional: configure through http://127.0.0.1:3000/setup instead.
APIFY_API_TOKEN=
OPENROUTER_API_KEY=

# Tested defaults; change actors and models to suit your provider accounts.
APIFY_LINKEDIN_ACTOR=curious_coder/linkedin-jobs-scraper
APIFY_INDEED_ACTOR=valig/indeed-jobs-scraper
OPENROUTER_MATCHING_MODEL=google/gemini-2.5-flash
OPENROUTER_WRITING_MODEL=google/gemini-2.5-flash

# SQLite database, uploaded profile image, and generated documents.
JOBPIPE_DATA_DIR=.jobpipe
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
